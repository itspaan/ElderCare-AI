# Copy this file to ".env" and fill in real values. ".env" is gitignored.

# Google Gemini API key (required for the chat agent).
GEMINI_API_KEY=your-gemini-api-key-here

# Persistent database for survey data (optional).
#
# Leave this UNSET for local development — survey data then goes to a local
# SQLite file at storage/survey.db (no extra setup needed).
#
# In production (e.g. Render free tier, where the disk is wiped on every
# redeploy) set this to a managed Postgres connection string so the research
# data survives. See docs/DEPLOYMENT.md §6 for step-by-step Supabase setup.
#
# Example (Supabase): copy the "Connection string > URI" and append sslmode:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxxxxxx.supabase.co:5432/postgres?sslmode=require
